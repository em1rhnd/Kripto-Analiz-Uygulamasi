<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">


    <ImageView
        android:id="@+id/btnGeri"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="40dp"
        android:src="@drawable/ic_geri"
        android:contentDescription="Geri"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <TextView
        android:id="@+id/tvProfilIsim"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="İsim"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toEndOf="@id/btnGeri"
        app:layout_constraintTop_toTopOf="@id/btnGeri"
        app:layout_constraintBottom_toBottomOf="@id/btnGeri" />

    <TextView
        android:id="@+id/tvProfilAlt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        android:text="Hesabım"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="24sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnGeri" />

    <LinearLayout
        android:id="@+id/containerUstKartlar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvProfilAlt"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/kartFavoriler"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="10dp"
            android:background="@drawable/card_profile">

            <ImageView
                android:id="@+id/imgFavoriler"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_favorite" />

            <TextView
                android:id="@+id/tvFavorilerKart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Favoriler"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorPrimary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/kartAyarlar"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="10dp"
            android:background="@drawable/card_profile">

            <ImageView
                android:id="@+id/imgAyarlar"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_settings" />

            <TextView
                android:id="@+id/tvAyarlarKart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ayarlar"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorPrimary" />
        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/tvFavoriBaslik"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Favori Coinlerim"
        android:textStyle="bold"
        android:textSize="18sp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="32dp"
        android:textColor="?android:attr/textColorPrimary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/containerUstKartlar" />


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFavoriler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvFavoriBaslik"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
