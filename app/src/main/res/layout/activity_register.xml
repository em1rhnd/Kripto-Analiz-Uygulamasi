<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:padding="24dp">

  <!-- Logo -->
  <ImageView
      android:id="@+id/logo_register"
      android:layout_width="376dp"
      android:layout_height="223dp"
      android:contentDescription="Logo"
      android:src="@drawable/ic2"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toTopOf="parent"/>

  <!-- İsim Soyisim -->
  <LinearLayout
      android:id="@+id/name_layout"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:background="@drawable/edittext_bg"
      android:orientation="horizontal"
      android:padding="8dp"
      app:layout_constraintTop_toBottomOf="@id/logo_register"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent"
      android:layout_marginTop="32dp">

    <ImageView
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="center_vertical"
        android:src="@drawable/ic_person"/>

    <EditText
        android:id="@+id/et_isimsoyisim"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:background="@null"
        android:hint="İsim Soyisim"
        android:inputType="textPersonName"/>
  </LinearLayout>

  <!-- Email -->
  <LinearLayout
      android:id="@+id/email_layout"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:background="@drawable/edittext_bg"
      android:orientation="horizontal"
      android:padding="8dp"
      app:layout_constraintTop_toBottomOf="@id/name_layout"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent"
      android:layout_marginTop="16dp">

    <ImageView
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="center_vertical"
        android:src="@drawable/ic_email"/>

    <EditText
        android:id="@+id/et_email"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:background="@null"
        android:hint="Email"
        android:inputType="textEmailAddress"/>
  </LinearLayout>

  <!-- Şifre -->
  <LinearLayout
      android:id="@+id/password_layout"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:background="@drawable/edittext_bg"
      android:orientation="horizontal"
      android:padding="8dp"
      app:layout_constraintTop_toBottomOf="@id/email_layout"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent"
      android:layout_marginTop="16dp">

    <ImageView
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="center_vertical"
        android:src="@drawable/ic_lock"/>

    <EditText
        android:id="@+id/et_sifre"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:background="@null"
        android:hint="Şifre"
        android:inputType="textPassword"/>
  </LinearLayout>

  <!-- Doğum Yılı -->
  <LinearLayout
      android:id="@+id/year_layout"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:background="@drawable/edittext_bg"
      android:orientation="horizontal"
      android:padding="8dp"
      app:layout_constraintTop_toBottomOf="@id/password_layout"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent"
      android:layout_marginTop="16dp">

    <ImageView
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="center_vertical"
        android:src="@drawable/ic_calendar"/>

    <EditText
        android:id="@+id/et_dogumyili"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:background="@null"
        android:hint="Doğum Yılı"
        android:inputType="number"/>
  </LinearLayout>

  <!-- Kayıt Butonu -->
  <Button
      android:id="@+id/btn_registerUser"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_marginTop="4dp"
      android:background="@drawable/button_background"
      android:padding="12dp"
      android:text="KAYIT OL"
      android:textColor="@android:color/black"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/year_layout"
      app:layout_constraintBottom_toTopOf="@id/btn_vazgec"/>

  <!-- Vazgeç Butonu -->
  <Button
      android:id="@+id/btn_vazgec"
      android:layout_width="wrap_content"
      android:layout_height="54dp"
      android:layout_marginTop="8dp"
      android:background="@drawable/button_background"
      android:drawableStart="@drawable/geri_don"
      android:padding="12dp"
      android:text="Vazgeç"
      android:textColor="@android:color/black"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/btn_registerUser" />
</androidx.constraintlayout.widget.ConstraintLayout>
